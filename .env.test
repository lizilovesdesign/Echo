# Test environment — used by CI and local test runs
# For local testing, spin up the test database with:
#   docker compose -f docker-compose.test.yml up -d
# Then run: npx prisma db push && npm test

DATABASE_URL="postgresql://postgres:postgres@localhost:5433/echo_test"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/echo_test"
TEST_SUPABASE_URL="http://localhost:54321"
TEST_SERVICE_ROLE_KEY="test-service-role-key"
