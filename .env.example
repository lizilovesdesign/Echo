# Database Configuration (Supabase PostgreSQL connection strings)
# DATABASE_URL: Supavisor transaction pooler — used at runtime by PrismaClient (serverless-safe)
# DIRECT_URL:  Direct connection — used by Prisma CLI for migrations only
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require"

# Supabase Auth Configuration
NEXT_PUBLIC_SUPABASE_URL="https://[project-id].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key-never-expose-client-side"

# Spotify API Configuration (for proxying music searches + user now-playing)
SPOTIFY_CLIENT_ID="your-spotify-client-id"
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"
# IMPORTANT: In your Spotify App Dashboard, add this exact redirect URI:
#   http://127.0.0.1:3000/api/auth/spotify/callback
# (Spotify no longer allows 'localhost' — must use 127.0.0.1 for local dev)
# Required OAuth scopes: user-read-currently-playing, user-read-playback-state

# Cryptographic Secret (for encrypting journal entries at rest)
JOURNAL_ENCRYPTION_SECRET="generate-a-32-character-random-string-for-encryption"

# SMTP Configuration (for sending transactional emails — welcome emails, password resets)
# Get a Resend API key at https://resend.com/api-keys
# Or use any SMTP provider (Gmail, SendGrid, Mailgun, etc.)
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASS="re_YOUR_ACTUAL_RESEND_API_KEY"
SMTP_FROM_EMAIL="noreply@yourdomain.com"
SMTP_FROM_NAME="Echo"

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
